{
  "cli": {
    "version": ">= 16.0.0",
    "requireCommit": false,
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "comment": "Dev client build for internal testers using Expo Dev Client. Fast iteration with hot reload.",
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.4:3000",
        "EXPO_PUBLIC_API_TIMEOUT": "15000",
        "EXPO_PUBLIC_COMPANY_SLUG": "sudama01",
        "EXPO_PUBLIC_COMPANY_NAME": "Sudama01",
        "EXPO_PUBLIC_USE_MOCK_API": "true",
        "EXPO_PUBLIC_WS_URL": "ws://192.168.1.4:3001"
      }
    },

    "preview": {
      "comment": "Internal preview build for QA & stakeholder review. No dev client — close to prod behaviour.",
      "developmentClient": false,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_TIMEOUT": "15000",
        "EXPO_PUBLIC_USE_MOCK_API": "false"
      }
    },

    "production": {
      "comment": "Production build submitted to Google Play Store and Apple App Store via EAS Submit.",
      "developmentClient": false,
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "simulator": false
      },
      "env": {
        "EXPO_PUBLIC_API_TIMEOUT": "15000",
        "EXPO_PUBLIC_USE_MOCK_API": "false"
      }
    }
  },

  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-service-account.json",
        "track": "internal",
        "releaseStatus": "draft",
        "changesNotSentForReview": true
      },
      "ios": {
        "appleId": "YOUR_APPLE_ID_EMAIL",
        "ascAppId": "YOUR_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "YOUR_APPLE_TEAM_ID"
      }
    }
  }
}
