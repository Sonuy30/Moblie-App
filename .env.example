# ══════════════════════════════════════════════════════════════════
#  AITS Shop — Environment Variable Template
#  Copy this file to .env.local and fill in your real values.
#  ⚠️  NEVER commit .env.local — it is gitignored.
#  ✅  COMMIT this file — it documents required variables.
# ══════════════════════════════════════════════════════════════════

# ── API ───────────────────────────────────────────────────────────
# Base URL of the AITS ERP backend.
# Local dev (real device): use your PC's Wi-Fi IP, e.g. http://192.168.x.x:3000
# Production:              https://aitserp-30072025.vercel.app
EXPO_PUBLIC_API_URL=

# Request timeout in milliseconds. Recommended: 15000 (15 s) for 3G tolerance.
EXPO_PUBLIC_API_TIMEOUT=

# ── Company ───────────────────────────────────────────────────────
# Readable slug that identifies the tenant (used in pre-login API calls).
# After login this is carried inside the JWT — no need to send again.
EXPO_PUBLIC_COMPANY_SLUG=

# Human-readable company name shown in the UI.
EXPO_PUBLIC_COMPANY_NAME=

# ── Payments ──────────────────────────────────────────────────────
# Razorpay publishable key. Use rzp_test_* for dev, rzp_live_* for production.
EXPO_PUBLIC_RAZORPAY_KEY=

# ── Feature Flags ─────────────────────────────────────────────────
# Set to "true" to enable mock API responses (no backend needed).
EXPO_PUBLIC_USE_MOCK_API=

# ── Future: Delivery Module ───────────────────────────────────────
# WebSocket endpoint for real-time order tracking (AITS Delivery).
EXPO_PUBLIC_WS_URL=

# ── Crash Reporting ───────────────────────────────────────────────
# Sentry DSN — get from https://sentry.io → Project Settings → Client Keys
# Leave blank to disable crash reporting (safe for local dev).
EXPO_PUBLIC_SENTRY_DSN=

