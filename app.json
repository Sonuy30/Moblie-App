{
  "expo": {
    "name": "AITS Shop",
    "slug": "aits-shop",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "aitsshop",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#185FA5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aits.shop"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#185FA5"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.aits.shop"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow AITS Shop to use the camera to scan invite QR codes."
        }
      ]
    ]
  }
}
